# PDF-экспорты в корне (визуальная сверка результата) — временные
/*.pdf

# Модель LLM: собранный .gguf НЕ коммитим (>100 МБ, лимит GitHub) —
# в git лежат куски models/*.gguf.partNNN (<100 МБ), модель склеивается
# из них автоматически при первом запуске (см. llm_correct._resolve_model).
models/*.gguf

# Модели Docling: собранные .safetensors НЕ коммитим (>100 МБ) — в git лежат
# куски *.safetensors.partNNN, склеиваются при первом запуске
# (pipeline._ensure_docling_models).
models/docling/**/*.safetensors
